# ============================================================
# NIGHTMARE INVEST — Environment Configuration Template
# ============================================================
# Copy this file to `.env` and fill in real values before running.
#
#   cp .env.example .env
#
# NEVER commit your real .env file. It is already in .gitignore.
# ============================================================

# ----- Database -------------------------------------------------
# DEV (default — SQLite file on disk, fully persistent across restarts):
DATABASE_URL="file:/home/z/my-project/db/custom.db"
#
# PRODUCTION (PostgreSQL):
#   1. Provision a Postgres database (e.g. on Supabase, Neon, RDS, or self-hosted).
#   2. Set the connection string below.
#   3. Open `prisma/schema.prisma` and change `provider = "sqlite"` to
#      `provider = "postgresql"`.
#   4. Run `bun run db:push` to create tables.
#   5. Run `bun run seed:admin` to create the admin user.
#
# DATABASE_URL="postgresql://user:password@host:5432/nightmare?schema=public"

# ----- Auth secrets (REQUIRED in production) --------------------
# Generate strong random secrets:
#   openssl rand -hex 64
#
# DO NOT use the dev fallbacks in production — the server will refuse
# to start in NODE_ENV=production if these are unset.
JWT_SECRET="change-me-to-a-64-byte-random-hex-string"
JWT_REFRESH_SECRET="change-me-to-a-different-64-byte-random-hex-string"
TOTP_OBFUS_KEY="change-me-to-a-32-byte-random-string"

# ----- Bootstrap admin credentials ------------------------------
# Used by `bun run seed:admin` and the `/api/bootstrap` endpoint to
# create the platform admin on first boot. Override before deploy.
ADMIN_EMAIL="ojas1234@nightmare.invest"
ADMIN_USERNAME="ojas1234"
ADMIN_PASSWORD="user1122"

# ----- Runtime --------------------------------------------------
NODE_ENV="development"
# In production, set to "production" — this enables secure cookies
# (requires HTTPS) and disables verbose Prisma logging.
