// NIGHTMARE INVEST — Institutional Crypto Hedge Fund Client Portal
// Prisma schema
//
// PORTABILITY: This schema is intentionally written using only portable
// primitives (String / Int / Float / Boolean / DateTime / cuid() ids, no
// native enums, no Bytes, no SQLite-only types). To run on PostgreSQL in
// production, switch the datasource provider below to "postgresql" and set
// DATABASE_URL to a postgres connection string — no other changes required.
//
//   provider = "postgresql"
//   url      = env("DATABASE_URL")  // e.g. postgresql://user:pass@host:5432/nightmare

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Switch to "postgresql" for production deployment. SQLite is used in dev
  // because the sandbox cannot install a postgres server binary. All
  // persistence semantics (users, sessions, transactions, investments,
  // ledger) are identical across both providers — Prisma abstracts them.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ----------------------------- Enums -----------------------------
// Both SQLite and PostgreSQL: we use String + app-level validation rather
// than native enums to keep the schema portable and to allow additive
// status values without migrations.

// ----------------------------- User ------------------------------
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("USER") // USER | ADMIN
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLogin    DateTime?

  // Two-factor authentication (TOTP)
  totpSecret   String?  // encrypted base32 secret
  totpEnabled  Boolean  @default(false)
  // One-time recovery codes (bcrypt-hashed, comma-joined in DB) — used if user loses authenticator
  recoveryCodes    String?
  recoveryCodesUsed Int     @default(0)

  // KYC verification status: NONE | PENDING | APPROVED | REJECTED
  kycStatus    String   @default("NONE")
  kycTier      String   @default("STANDARD") // STANDARD | ACCREDITED
  kycReviewedBy String?
  kycReviewedAt DateTime?
  kycNotes     String?

  holdings     Holding[]
  transactions Transaction[]
  ledgerEntries LedgerEntry[] @relation("LedgerUser")
  auditLogs    AuditLog[]     @relation("AuditActor")
  processedTxn Transaction[]  @relation("ProcessedBy")
  reports      Report[]
  kycDocuments KycDocument[]
  reviewedKyc  KycDocument[] @relation("KycReviewer")
  fundUpdates  FundUpdate[]  @relation("FundUpdateAuthor")
  watchlist    WatchlistItem[]
  sentMessages     AdminMessage[] @relation("SentMessages")
  receivedMessages AdminMessage[] @relation("ReceivedMessages")
  documents        Document[]
  statementRequests          StatementRequest[] @relation("StatementRequestRequester")
  processedStatementRequests StatementRequest[] @relation("StatementRequestProcessor")
  investments      Investment[]

  // Persistent auth — refresh tokens, sessions, 2FA challenges, notification reads
  refreshTokens    RefreshToken[]
  sessions         Session[]
  authChallenges   AuthChallenge[]
  notificationReads NotificationRead[]
}

// ----------------------------- Fund ------------------------------
model Fund {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  description  String
  minInvest    Float    @default(50000)
  feeStructure String   @default("2% management / 20% performance")
  isActive     Boolean  @default(true)
  inceptionNav Float    @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  navPoints    NAVPoint[]
  holdings     Holding[]
  transactions Transaction[]
  allocations  Allocation[]
  investments  Investment[]
}

// Allocation of the fund across assets (admin controlled)
model Allocation {
  id       String  @id @default(cuid())
  fundId   String
  fund     Fund    @relation(fields: [fundId], references: [id], onDelete: Cascade)
  asset    String  // e.g. BTC, ETH, SOL, Stablecoin, Altcoins
  weight   Float   // percentage 0-100
  color    String  @default("#D4AF37")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fundId, asset])
}

// ----------------------------- NAV -------------------------------
model NAVPoint {
  id        String   @id @default(cuid())
  fundId    String
  fund      Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  date      DateTime
  nav       Float
  aum       Float?
  createdAt DateTime @default(now())

  @@unique([fundId, date])
}

// --------------------------- Holdings ----------------------------
model Holding {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fundId    String
  fund      Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  units     Float
  avgPrice  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, fundId])
}

// ------------------------- Transactions --------------------------
model Transaction {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fundId     String
  fund       Fund      @relation(fields: [fundId], references: [id], onDelete: Cascade)
  type       String    // DEPOSIT | WITHDRAWAL
  amount     Float
  status     String    @default("PENDING") // PENDING | APPROVED | REJECTED
  notes      String?
  processedBy String?
  processor  User?     @relation("ProcessedBy", fields: [processedBy], references: [id])
  createdAt  DateTime  @default(now())
  processedAt DateTime?

  // Deposit / withdrawal method + optional crypto amount (for minimum validation)
  method     String    @default("UPI") // UPI | BTC | LTC | USDT
  cryptoAmount Float?  // raw crypto amount (e.g. 0.0005 BTC); null for UPI
  usdValue   Float?    // USD equivalent at request time (for crypto methods)
  // Proof of payment reference — UTR (UPI) or on-chain transaction hash (crypto).
  // Required for deposits so admin can verify payment before approval.
  proofRef   String?
}

// ------------------------- Investments ---------------------------
// Admin-managed investments — admin creates positions on behalf of investors.
// Tracks invested capital, current value, profit/loss, ROI and lifecycle.
model Investment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fundId          String
  fund            Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  investmentName  String
  investedAmount  Float
  currentValue    Float
  profitLoss      Float    @default(0)
  roiPercent      Float    @default(0)
  startDate       DateTime
  endDate         DateTime?
  durationDays    Int      @default(0)
  status          String   @default("PENDING") // PENDING | ACTIVE | COMPLETED | CLOSED | CANCELLED
  notes           String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  history         InvestmentHistory[]

  @@index([userId])
  @@index([fundId])
  @@index([status])
}

// --------------------- Investment History ------------------------
// Append-only audit trail of value/ROI changes for each investment.
model InvestmentHistory {
  id            String   @id @default(cuid())
  investmentId  String
  investment    Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  previousValue Float
  newValue      Float
  previousRoi   Float
  newRoi        Float
  updatedBy     String?
  createdAt     DateTime @default(now())

  @@index([investmentId])
}

// --------------------------- Ledger ------------------------------
model LedgerEntry {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("LedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  accountId    String   // user-fund account key
  amount       Float    // signed (+ deposit, - withdrawal)
  type         String   // DEPOSIT | WITHDRAWAL | NAV_ADJUST | FEE | INVESTMENT_ALLOC | INVESTMENT_RELEASE
  balanceAfter Float
  reference    String?  // transaction id
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([accountId])
}

// ------------------------- Audit Logs ----------------------------
model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  actor        User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action       String
  resourceType String?
  resourceId   String?
  metadata     String?  // JSON string
  timestamp    DateTime @default(now())
  // SHA-256 hash chaining for tamper-evident immutable audit trail (compliance)
  prevHash     String?  // hash of the previous audit log entry
  hash         String?  // hash of this entry's canonical content + prevHash
  chainIndex   Int      @default(0) // sequence position in the chain

  @@index([actorId])
  @@index([action])
}

// --------------------------- Reports -----------------------------
model Report {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  period      String   // e.g. 2025-Q1
  type        String   // STATEMENT | QUARTERLY | PERFORMANCE
  summary     String
  createdAt   DateTime @default(now())
}

// ----------------------- Market Cache ----------------------------
// Cache live crypto prices to avoid hammering upstream APIs
model MarketPrice {
  id        String   @id @default(cuid())
  symbol    String   @unique // bitcoin, ethereum, solana
  name      String
  priceUsd  Float
  change24h Float
  updatedAt DateTime @updatedAt
}

// ------------------------ Fund Updates ---------------------------
// News, commentary and updates posted by fund administrators
model FundUpdate {
  id         String   @id @default(cuid())
  title      String
  body       String
  category   String   @default("GENERAL") // GENERAL | PERFORMANCE | STRATEGY | REGULATORY | MARKET
  priority   String   @default("NORMAL")   // NORMAL | IMPORTANT | URGENT
  pinned     Boolean  @default(false)
  authorId   String?
  author     User?    @relation("FundUpdateAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([category])
  @@index([pinned])
}

// ------------------------ KYC Documents --------------------------
// Documents uploaded by investors for identity/accreditation verification
model KycDocument {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // GOVT_ID | PROOF_OF_ADDRESS | ACCREDITATION | SELFIE | SOURCE_OF_FUNDS
  fileName   String
  filePath   String   // relative path under /upload
  mimeType   String
  sizeBytes  Int
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED
  notes      String?
  reviewedBy String?
  reviewer   User?    @relation("KycReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([status])
}

// ------------------------ Watchlist Items -------------------------
// Investor watchlist for tracking favorite crypto assets with price alerts
model WatchlistItem {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol         String   // bitcoin, ethereum, solana, etc.
  name           String   // Bitcoin, Ethereum, Solana
  alertPrice     Float?   // price alert threshold (nullable)
  alertDirection  String?  @default("ABOVE") // ABOVE | BELOW
  notes          String?
  createdAt      DateTime @default(now())

  @@unique([userId, symbol])
  @@index([userId])
}

// ------------------------ Admin Messages -------------------------
// Admin-to-investor messaging system (individual + broadcast)
model AdminMessage {
  id          String    @id @default(cuid())
  senderId    String
  sender      User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   User?     @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: SetNull)
  subject     String
  body        String
  priority    String    @default("NORMAL") // NORMAL | IMPORTANT | URGENT
  isBroadcast Boolean   @default(false) // true = sent to all investors
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([recipientId])
  @@index([senderId])
  @@index([isBroadcast])
}

// ------------------------ Documents Vault ------------------------
// Investor documents: monthly statements, tax forms, trade confirmations, etc.
model Document {
  id          String   @id @default(cuid())
  userId      String   // Owning investor (recipient)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String   // Display title, e.g. "June 2026 Monthly Statement"
  type        String   // MONTHLY_STATEMENT | QUARTERLY_REPORT | TAX_STATEMENT | TRADE_CONFIRMATION | ACCOUNT_STATEMENT | CUSTOM
  period      String?  // e.g. "2026-06" or "2026-Q2"
  description String?
  fileName    String   // stored filename on disk
  filePath    String   // absolute or relative path under /download or /upload
  mimeType    String   // application/pdf, image/png, etc.
  sizeBytes   Int
  generatedBy String?  // null = admin uploaded; otherwise admin userId
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// --------------------- Statement Requests ------------------------
// Investor-initiated requests for official statements
model StatementRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("StatementRequestRequester", fields: [userId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  type        String   @default("MONTHLY_STATEMENT") // MONTHLY_STATEMENT | QUARTERLY_REPORT | TAX_STATEMENT | CUSTOM
  notes       String?
  status      String   @default("PENDING") // PENDING | COMPLETED | REJECTED
  documentId  String?  // link to generated Document when COMPLETED
  processedBy String?
  processor   User?    @relation("StatementRequestProcessor", fields: [processedBy], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([status])
}

// --------------------- System Settings ---------------------------
// Platform-wide key-value configuration (admin editable via /admin/settings).
// Stores security policy, fee config, feature flags, etc.
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON-encoded value
  category  String   @default("general") // general | security | fees | notifications | features
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// =================================================================
// PERSISTENT AUTHENTICATION MODELS
// =================================================================
// All auth state is stored in the database so sessions survive server
// restarts, can be revoked from any device, and can be audited. No
// in-memory token stores — every refresh token, 2FA challenge, session,
// and notification read-receipt is durably persisted.
// =================================================================

// ------------------------ Refresh Tokens -------------------------
// Persisted, revocable, rotating refresh tokens for the JWT auth flow.
// Each login issues one refresh token; each refresh rotates it (old token
// is revoked, new one is issued). Allows server-side session revocation
// and "log out everywhere" functionality.
model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SHA-256 hash of the raw JWT — we never store the raw token in the DB,
  // so a DB dump cannot be used to forge sessions.
  tokenHash   String    @unique
  // JTI (JWT ID) claim, mirrored here for fast lookup by claim
  jti         String    @unique
  // SHA-256 of the user-agent for device fingerprinting
  userAgent   String?
  // Truncated IP for audit (last octet zeroed for privacy)
  ip          String?
  expiresAt   DateTime
  revokedAt   DateTime? // null = active; set on logout/rotation/revoke
  replacedBy  String?   // id of the RefreshToken that replaced this one (rotation chain)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// --------------------------- Sessions ----------------------------
// High-level device sessions — one per login. Lets users see "logged in
// on Chrome / Windows" and revoke individual sessions from settings.
// Backed by RefreshToken for actual JWT validation.
model Session {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Human-readable device label, e.g. "Chrome 130 on macOS"
  deviceLabel String
  // Truncated IP for audit
  ip          String?
  userAgent   String?
  // SHA-256 hash of the underlying refresh token's jti
  refreshJti  String    @unique
  lastSeenAt  DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([revokedAt])
}

// ----------------------- Auth Challenges -------------------------
// Short-lived 2FA (TOTP) challenge tickets persisted in DB so they
// survive server restarts and work across multi-instance deployments.
// Status: PENDING -> COMPLETED | EXPIRED | CONSUMED
model AuthChallenge {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Opaque ticket the client must echo back: 32-byte base64url random
  ticket    String    @unique
  status    String    @default("PENDING") // PENDING | COMPLETED | EXPIRED
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([status])
}

// -------------------- Notification Reads -------------------------
// Persistent per-user read receipts for notifications, replacing the
// prior in-memory Map<userId, Set<notificationId>> which was lost on
// every server restart.
model NotificationRead {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Stable notification id derived from the underlying event
  // (e.g. "txn:cmr0phydl0000rfedfcd32xsh:APPROVED")
  notificationId  String
  readAt          DateTime @default(now())

  @@unique([userId, notificationId])
  @@index([userId])
}
